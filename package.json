{
  "name": "face-recognition-attendance",
  "version": "2.0.0",
  "description": "React, Express, and MySQL face recognition attendance system.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "vite --host 0.0.0.0",
    "server:dev": "nodemon server/index.js",
    "migrate": "node server/migrate.js",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "mysql2": "^3.15.3",
    "vite": "^7.1.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "keywords": [
    "attendance",
    "face-recognition",
    "react",
    "mysql"
  ],
  "license": "MIT"
}
